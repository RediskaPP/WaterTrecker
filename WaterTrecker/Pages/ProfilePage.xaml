<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaterTrecker.Pages.ProfilePage"
             Title="Профиль">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- АВАТАР -->
            <Border Style="{StaticResource Card}" Padding="28,24">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">

                    <!-- Иконка в голубом круге -->
                    <Border BackgroundColor="#E8F4FD"
                            StrokeShape="RoundRectangle 50"
                            StrokeThickness="0"
                            HeightRequest="96"
                            WidthRequest="96"
                            HorizontalOptions="Center">
                        <Label Text="👤"
                               FontSize="48"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <Label Text="Пользователь"
                           Style="{StaticResource DisplayLabel}"
                           FontSize="22"
                           Margin="0,4,0,0"/>

                    <Label Text="Отслеживай водный баланс каждый день"
                           Style="{StaticResource CaptionLabel}"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>
            </Border>

            <!-- СТАТИСТИКА -->
            <Label Text="Статистика"
                   Style="{StaticResource SectionLabel}"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <!-- Сегодня -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="💧"
                               FontSize="24"
                               HorizontalTextAlignment="Center"/>
                        <Label x:Name="LblToday"
                               Text="—"
                               TextColor="#1A9BE8"
                               FontSize="26"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Сегодня"
                               Style="{StaticResource CaptionLabel}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Записей -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📋"
                               FontSize="24"
                               HorizontalTextAlignment="Center"/>
                        <Label x:Name="LblRecords"
                               Text="—"
                               TextColor="#1A9BE8"
                               FontSize="26"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Записей"
                               Style="{StaticResource CaptionLabel}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- ДОСТИЖЕНИЯ -->
            <Label Text="Достижения"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout x:Name="BadgeLayout" Spacing="10"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
