<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaterTrecker.Pages.DashboardPage"
             Title="Главная">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- дата + прогресс -->
            <Border Style="{StaticResource Card}" Padding="24,20">
                <VerticalStackLayout Spacing="12">

                    <!-- Дата -->
                    <Label x:Name="LblDate"
                           Style="{StaticResource CaptionLabel}"
                           HorizontalTextAlignment="Center"
                           FontAttributes="Bold"
                           CharacterSpacing="0.8"
                           TextTransform="Uppercase"/>

                    <!-- Выпито -->
                    <Label x:Name="LblCurrent"
                           Text="0 мл"
                           Style="{StaticResource DisplayLabel}"/>

                    <!-- Из цели -->
                    <Label x:Name="LblGoal"
                           Text="из 2500 мл"
                           Style="{StaticResource CaptionLabel}"
                           HorizontalTextAlignment="Center"/>

                    <!-- Прогресс бар -->
                    <ProgressBar x:Name="ProgressBar"
                                 Progress="0"
                                 Margin="0,4"/>

                    <!-- Мотивация -->
                    <Label x:Name="LblMotivation"
                           Style="{StaticResource HintLabel}"
                           Margin="0,4,0,0"/>

                </VerticalStackLayout>
            </Border>

            <!-- БЫСТРОЕ ДОБАВЛЕНИЕ -->
            <Label Text="Быстро добавить"
                   Style="{StaticResource SectionLabel}"/>

            <HorizontalStackLayout Spacing="10">
                <Button Text="💧 150 мл"
                        Style="{StaticResource ChipButton}"
                        Clicked="OnAdd150"/>
                <Button Text="🥤 250 мл"
                        Style="{StaticResource ChipButton}"
                        Clicked="OnAdd250"/>
                <Button Text="🍶 500 мл"
                        Style="{StaticResource ChipButton}"
                        Clicked="OnAdd500"/>
            </HorizontalStackLayout>

            <!-- ЗАПИСИ ЗА СЕГОДНЯ -->
            <Label Text="Сегодня"
                   Style="{StaticResource SectionLabel}"/>

            <!-- Пустое состояние -->
            <Border x:Name="LblEmptyWrapper"
                    Style="{StaticResource Card}"
                    Padding="24,32"
                    IsVisible="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="💧"
                           FontSize="36"
                           HorizontalTextAlignment="Center"/>
                    <Label x:Name="LblEmpty"
                           Text="Нет записей. Добавь первый стакан!"
                           Style="{StaticResource HintLabel}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Лог -->
            <CollectionView x:Name="WaterLogList"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 14"
                                Stroke="#D6EAF8"
                                StrokeThickness="1"
                                Padding="14,12">
                            <Border.Shadow>
                                <Shadow Brush="#1A1A9BE8"
                                        Offset="0,3"
                                        Radius="8"
                                        Opacity="0.1"/>
                            </Border.Shadow>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>

                                <!-- Иконка напитка в кружке -->
                                <Border Grid.Column="0"
                                        BackgroundColor="#E8F4FD"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="0"
                                        HeightRequest="44"
                                        WidthRequest="44">
                                    <Label Text="{Binding Icon}"
                                           FontSize="22"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Border>

                                <!-- Тип и время -->
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center"
                                                     Spacing="2">
                                    <Label Text="{Binding DrinkType}"
                                           TextColor="#0D2B45"
                                           FontSize="15"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding TimeDisplay}"
                                           TextColor="#5A87A8"
                                           FontSize="12"/>
                                </VerticalStackLayout>

                                <!-- Объём -->
                                <Label Grid.Column="2"
                                       Text="{Binding Amount, StringFormat='{0} мл'}"
                                       TextColor="#1A9BE8"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>

                                <!-- Удалить -->
                                <Button Grid.Column="3"
                                        Text="✕"
                                        Style="{StaticResource DangerIconButton}"
                                        CommandParameter="{Binding Id}"
                                        Clicked="OnDelete"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>