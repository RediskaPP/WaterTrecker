<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaterTrecker.Pages.AddRecordPage"
             Title="Добавить запись">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- ОБЪЁМ -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Объём"
                           Style="{StaticResource SectionLabel}"
                           Margin="0"/>

                    <!-- Большое число -->
                    <Label x:Name="LblAmount"
                           Text="250 мл"
                           Style="{StaticResource DisplayLabel}"/>

                    <!-- Слайдер -->
                    <Slider x:Name="SliderAmount"
                            Minimum="50"
                            Maximum="1000"
                            Value="250"
                            ValueChanged="OnSliderChanged"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                        <Label Grid.Column="0"
                               Text="50 мл"
                               Style="{StaticResource CaptionLabel}"
                               HorizontalTextAlignment="Start"/>
                        <Label Grid.Column="1"
                               Text="1000 мл"
                               Style="{StaticResource CaptionLabel}"
                               HorizontalTextAlignment="End"/>
                    </Grid>

                    <!-- Разделитель -->
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#D6EAF8, Dark=#1E3347}"
                             Margin="0,4"/>

                    <!-- Ввод вручную -->
                    <Label Text="Или введите точное значение"
                           Style="{StaticResource CaptionLabel}"/>

                    <Border Style="{StaticResource InputBorder}">
                        <Entry x:Name="EntryAmount"
                               Placeholder="например, 330"
                               Keyboard="Numeric"
                               TextChanged="OnEntryChanged"
                               HeightRequest="48"/>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ТИП НАПИТКА -->
            <Label Text="Тип напитка"
                   Style="{StaticResource SectionLabel}"/>

            <CollectionView x:Name="DrinkList"
                            SelectionMode="Single"
                            SelectionChanged="OnDrinkSelected"
                            HeightRequest="80">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource DrinkCardBorder}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Icon}"
                                       FontSize="26"
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource DrinkNameLabel}"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ВРЕМЯ -->
            <Label Text="Время"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}"
                    Padding="16,0"
                    HeightRequest="60">
                <Grid ColumnDefinitions="Auto,*"
                      VerticalOptions="Center">
                    <Label Grid.Column="0"
                           Text="🕐"
                           FontSize="20"
                           VerticalOptions="Center"
                           VerticalTextAlignment="Center"
                           HorizontalOptions="Center"
                           Margin="0,0,12,0"/>
                    <TimePicker Grid.Column="1"
                                x:Name="TimePicker"
                                Format="HH:mm"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"/>
                </Grid>
            </Border>

            <!-- КНОПКА СОХРАНИТЬ -->
            <Button Text="Сохранить запись"
                    Clicked="OnSave"
                    Margin="0,8,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
