<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaterTrecker.Pages.SettingsPage"
             Title="Настройки">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- ЗАГОЛОВОК -->
            <Label Text="Настройки"
                   Style="{StaticResource DisplayLabel}"
                   HorizontalTextAlignment="Start"
                   FontSize="28"/>

            <!-- ДНЕВНАЯ ЦЕЛЬ -->
            <Label Text="Цель"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Дневная цель потребления воды"
                           Style="{StaticResource BodyLabel}"
                           FontAttributes="Bold"/>
                    <Label Text="Рекомендуемая норма — 2000–2500 мл в день"
                           Style="{StaticResource CaptionLabel}"/>

                    <Border Style="{StaticResource InputBorder}" Margin="0,4,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   x:Name="EntryGoal"
                                   Keyboard="Numeric"
                                   Placeholder="2000"
                                   HeightRequest="50"/>
                            <Label Grid.Column="1"
                                   Text="мл"
                                   Style="{StaticResource CaptionLabel}"
                                   VerticalOptions="Center"
                                   Margin="0,0,4,0"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ВНЕШНИЙ ВИД -->
            <Label Text="Внешний вид"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label Text="Тёмная тема"
                               Style="{StaticResource BodyLabel}"
                               FontAttributes="Bold"/>
                        <Label Text="Переключить тёмный режим интерфейса"
                               Style="{StaticResource CaptionLabel}"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            x:Name="SwitchDarkMode"
                            Toggled="OnThemeChanged"
                            OnColor="#1A9BE8"
                            ThumbColor="White"
                            VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ОПАСНАЯ ЗОНА -->
            <Label Text="Данные"
                   Style="{StaticResource SectionLabel}"
                   Margin="0,8,0,0"/>

            <Border BackgroundColor="{AppThemeBinding Light=#FDEEF0, Dark=#2A1520}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#F5C6CB, Dark=#4A2530}"
                    StrokeThickness="1"
                    Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Очистить все записи"
                           TextColor="{AppThemeBinding Light=#0D2B45, Dark=#E8F4FD}"
                           FontSize="15"
                           FontAttributes="Bold"/>
                    <Label Text="Это действие удалит всю историю потребления воды. Отменить нельзя."
                           TextColor="{AppThemeBinding Light=#8B4A54, Dark=#D49AA3}"
                           FontSize="13"/>
                    <Button Text="Удалить все данные"
                            Clicked="OnClearData"
                            BackgroundColor="#E05A6A"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="46"
                            FontAttributes="Bold"
                            Margin="0,4,0,0">
                        <Button.Shadow>
                            <Shadow Brush="#40E05A6A" Offset="0,3" Radius="8" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Border>

            <!-- СОХРАНИТЬ -->
            <Button Text="Сохранить настройки"
                    Clicked="OnSave"
                    Margin="0,4,0,16"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
