<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaterTrecker.Pages.NotificationsPage"
             Title="Напоминания">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- ЗАГОЛОВОК -->
            <Label Text="Напоминания"
                   Style="{StaticResource DisplayLabel}"
                   HorizontalTextAlignment="Start"
                   FontSize="28"/>

            <!-- ВКЛЮЧИТЬ НАПОМИНАНИЯ -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="4"
                                         VerticalOptions="Center">
                        <Label Text="Напоминания включены"
                               Style="{StaticResource BodyLabel}"
                               FontAttributes="Bold"/>
                        <Label Text="Напоминать пить воду в течение дня"
                               Style="{StaticResource CaptionLabel}"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding Settings.Enabled}"
                            OnColor="#1A9BE8"
                            ThumbColor="White"
                            VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ИНТЕРВАЛ -->
            <Label Text="Интервал"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding IntervalText}"
                           TextColor="#1A9BE8"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Напоминание будет приходить с этим интервалом"
                           Style="{StaticResource CaptionLabel}"
                           HorizontalTextAlignment="Center"/>

                    <!-- Кнопки ± -->
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12" HorizontalOptions="Center" WidthRequest="180">
                        <Button Grid.Column="0"
                                Text="−"
                                Clicked="MinusClicked"
                                BackgroundColor="#E8F4FD"
                                TextColor="#1A9BE8"
                                FontSize="20"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                WidthRequest="64">
                            <Button.Shadow>
                                <Shadow Brush="Transparent" Offset="0,0" Radius="0" Opacity="0"/>
                            </Button.Shadow>
                        </Button>
                        <Label Grid.Column="1"
                               Text="интервал"
                               Style="{StaticResource CaptionLabel}"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Grid.Column="2"
                                Text="+"
                                Clicked="PlusClicked"
                                BackgroundColor="#1A9BE8"
                                TextColor="White"
                                FontSize="20"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"
                                WidthRequest="64">
                            <Button.Shadow>
                                <Shadow Brush="#401A9BE8" Offset="0,3" Radius="8" Opacity="0.25"/>
                            </Button.Shadow>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ТИХИЕ ЧАСЫ -->
            <Label Text="Тихие часы"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Не беспокоить в это время"
                           Style="{StaticResource CaptionLabel}"/>

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">

                        <Border Grid.Column="0"
                                BackgroundColor="#F0F8FF"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#D6EAF8"
                                StrokeThickness="1"
                                Padding="10,0">
                            <TimePicker Time="{Binding Settings.QuietStart}"
                                        TextColor="#0D2B45"
                                        BackgroundColor="Transparent"
                                        HeightRequest="48"/>
                        </Border>

                        <Label Grid.Column="1"
                               Text="—"
                               TextColor="#5A87A8"
                               FontSize="18"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Center"/>

                        <Border Grid.Column="2"
                                BackgroundColor="#F0F8FF"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#D6EAF8"
                                StrokeThickness="1"
                                Padding="10,0">
                            <TimePicker Time="{Binding Settings.QuietEnd}"
                                        TextColor="#0D2B45"
                                        BackgroundColor="Transparent"
                                        HeightRequest="48"/>
                        </Border>

                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- БЛИЖАЙШИЕ УВЕДОМЛЕНИЯ -->
            <Label Text="Ближайшие уведомления"
                   Style="{StaticResource SectionLabel}"/>

            <Border Style="{StaticResource Card}" Padding="16">
                <CollectionView ItemsSource="{Binding UpcomingNotifications}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    BackgroundColor="#E8F4FD"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    Padding="14,10">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0"
                                           Text="🔔"
                                           FontSize="16"
                                           VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding}"
                                           TextColor="#0D2B45"
                                           FontSize="15"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
