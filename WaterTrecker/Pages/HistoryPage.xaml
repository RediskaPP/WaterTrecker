<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="WaterTrecker.Pages.HistoryPage"
    Title="История">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label
            Text="История записей"
            FontSize="24"
            FontAttributes="Bold"/>

        <DatePicker
            x:Name="DatePickerHistory"
            DateSelected="OnDateSelected"/>

        <Label
            x:Name="LblTotal"
            Text="Всего: 0 мл"
            FontSize="18"/>

        <CollectionView
            x:Name="HistoryList">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10">
                        <Grid ColumnDefinitions="40,*,80">

                            <Label
                                Grid.Column="0"
                                Text="{Binding Icon}"
                                FontSize="24"/>

                            <VerticalStackLayout Grid.Column="1">

                                <Label
                                    Text="{Binding DrinkType}"
                                    FontAttributes="Bold"/>

                                <Label
                                    Text="{Binding Timestamp}"
                                    FontSize="12"/>

                            </VerticalStackLayout>

                            <Label
                                Grid.Column="2"
                                Text="{Binding Amount}"
                                HorizontalOptions="End"
                                VerticalOptions="Center"/>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>