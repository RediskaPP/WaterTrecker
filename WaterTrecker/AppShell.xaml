<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WaterTrecker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:WaterTrecker"
    xmlns:pages="clr-namespace:WaterTrecker.Pages"
    Title="WaterTrecker">

    <TabBar>
        <Tab Title="Главная">
            <ShellContent Route="dashboard"
                  ContentTemplate="{DataTemplate pages:DashboardPage}"/>
        </Tab>
        <Tab Title="Добавить">
            <ShellContent Route="addrecord"
                          ContentTemplate="{DataTemplate pages:AddRecordPage}"/>
        </Tab>
        <Tab Title="История">
            <ShellContent Route="history"
                  ContentTemplate="{DataTemplate pages:HistoryPage}"/>
        </Tab>
        <Tab Title="Настиройки">
            <ShellContent Route="settings"
                ContentTemplate="{DataTemplate pages:SettingsPage}"/>
        </Tab>
        <Tab Title="Уведомление">
            <ShellContent Route="notifications"
                 ContentTemplate="{DataTemplate pages:NotificationsPage}"/>
        </Tab>
        <Tab Title="Профиль">
            <ShellContent Route="profile"
         ContentTemplate="{DataTemplate pages:ProfilePage}"/>
        </Tab>
    </TabBar>

</Shell>
